<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.DialogPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ButtonType?>

<DialogPane xmlns:fx="http://javafx.com/fxml" stylesheets="@css/removeRecipeDialog.css"
  fx:controller="is.vidmot.controller.RemoveRecipeDialogController">
  <content>
    <Label text="Are you sure you want to remove this recipe?" />
  </content>
  <buttonTypes>
    <ButtonType fx:constant="OK" />
    <ButtonType fx:constant="CANCEL" />
  </buttonTypes>
</DialogPane>
