<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<fx:root alignment="CENTER" prefHeight="500.0" prefWidth="600.0" spacing="10" type="VBox" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
  <padding>
    <Insets bottom="15" left="15" right="15" top="15" />
  </padding>

  <HBox alignment="CENTER" spacing="10">
    <Label text="Name:">
         <font>
            <Font size="16.0" />
         </font></Label>
    <TextField fx:id="nameField" editable="false">
         <font>
            <Font size="16.0" />
         </font></TextField>
  </HBox>
  <HBox alignment="CENTER" spacing="10">
    <Label text="Servings:">
         <font>
            <Font size="16.0" />
         </font></Label>
    <TextField fx:id="servingsField" editable="false" promptText="0">
         <font>
            <Font size="16.0" />
         </font></TextField>
  </HBox>

  <HBox alignment="CENTER" spacing="10">
    <Label text="Time:">
         <font>
            <Font size="16.0" />
         </font></Label>
    <TextField fx:id="cookTimeField" editable="false" promptText="0m">
         <font>
            <Font size="16.0" />
         </font></TextField>
  </HBox>
   <HBox alignment="CENTER" layoutX="25.0" layoutY="207.0" spacing="10">
      <children>
         <Label text="Calories">
            <font>
               <Font size="16.0" />
            </font>
         </Label>
         <TextField fx:id="caloriesField" editable="false" promptText="0kcal">
            <font>
               <Font size="16.0" />
            </font>
         </TextField>
      </children>
   </HBox>
   <HBox alignment="CENTER" layoutX="25.0" layoutY="131.0" spacing="10">
      <children>
         <Label text="Protein/Carbs/Fat">
            <font>
               <Font size="16.0" />
            </font>
         </Label>
         <TextField fx:id="proteinField" editable="false" prefWidth="70.0" promptText="0g">
            <font>
               <Font size="16.0" />
            </font>
         </TextField>
         <TextField fx:id="carbsField" prefWidth="70.0" promptText="0g">
            <font>
               <Font size="16.0" />
            </font>
         </TextField>
         <TextField fx:id="fatField" prefWidth="70.0" promptText="0g">
            <font>
               <Font size="16.0" />
            </font>
         </TextField>
      </children>
   </HBox>
   <HBox alignment="CENTER" layoutX="25.0" layoutY="328.0" spacing="10">
      <children>
         <Label text="Difficulty:">
            <font>
               <Font size="16.0" />
            </font>
         </Label>
         <ComboBox fx:id="diffComboBox" prefWidth="150.0" promptText="Choose" />
      </children>
   </HBox>
   <HBox alignment="CENTER" layoutX="25.0" layoutY="349.0" spacing="10">
      <children>
         <Label text="Description:">
            <font>
               <Font size="16.0" />
            </font>
         </Label>
         <TextArea fx:id="descriptionArea" prefHeight="200.0" prefWidth="200.0" />
      </children>
   </HBox>
</fx:root>
