<?xml version="1.0" encoding="UTF-8"?>

<?import is.vidmot.view.RecipeCard?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="862.0" prefWidth="700.0" spacing="5" stylesheets="@css/recipe.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="is.vidmot.controller.RecipeController">

  <RecipeCard fx:id="fxRecipeCard" alignment="CENTER" />
   <HBox alignment="BOTTOM_CENTER" spacing="20.0" prefHeight="50.0" prefWidth="200.0">
      <children>
       <Button fx:id="fxBackButton" onAction="#fxOnBack" text="Back" />
         <Button fx:id="fxUpdateButton" layoutX="321.0" layoutY="71.0" onAction="#fxOnUpdate" text="Update">
            <font>
               <Font size="16.0" />
            </font>
         </Button>
         <Button fx:id="fxOkButton" mnemonicParsing="false" onAction="#fxOnOk" text="OK" visible="false" />
      </children>
      <VBox.margin>
         <Insets bottom="10.0" />
      </VBox.margin>
   </HBox>
</VBox>
